
<% layout('/layout/boilerplate') -%>
<div class="row">

<div class=" offset-2 ">


 <h2>Create a New Listing..</h2>

    <form method="POST" action="/listings">  
        <div class="mb-3">
    <lable for="title" class="form-label">Title</lable>  
        <input name="Listing[title]" placeholder="enter title" type="text" class="form-control" />
       
        </div>
    <div class="mb-3">
         <lable for="description" class="form-label">Description</lable>  
     <textarea name="Listing[description]" class="form-control" placeholder="enter description" type="text"></textarea>
   

    </div>


    <div class="mb-3">
     <lable for="image" class="form-label">image</lable>     
  <input name="Listing[image]" placeholder="enter image URl" type="text" class="form-control" />
       
    </div>
    <div class="mb-3">
   <lable for="price" class="form-label">Price</lable>     
   <input name="Listing[price]" placeholder="1200" type="number"  class="form-control" />
       

    </div>
      
    <div class="mb-3">

         <lable for="country" class="form-label">Country</lable>     
           <input name="Listing[country]" placeholder="Delhi" type="text"  class="form-control" />
        
    </div>

    <div class="mb-3">
     <lable for="location" class="form-label">location</lable>        
    <input name="Listing[location]" placeholder="Park Evenu" type="text" />
      
    </div>
      

            <button class="btn btn-dark add-btn">Add</button>
    </form>
    

</div>
</div>